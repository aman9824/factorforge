# FactorForge configuration — copy to `.env` and edit. Every var is optional; the defaults
# run the whole pipeline offline + deterministically (mock LLM, mock agents, synthetic data).

# ── Seam selection ──────────────────────────────────────────────────────────
# FF_LLM_PROVIDER=mock        # mock | vertex   (extraction / summaries / tree navigation)
# FF_AGENT_BACKEND=mock       # mock | claude   (the 5-role research pipeline)
# FF_DATA_SOURCE=synthetic    # synthetic | french   (backtest price/return panel)

# ── Vertex AI (only when a real seam is selected; auth via ADC) ──────────────
#   gcloud auth application-default login
# FF_VERTEX_PROJECT_ID=ford-bbfd8f90a37aa7c3fcd1ded7
# FF_VERTEX_REGION=global                  # Opus 4.x is global-endpoint only
# FF_VERTEX_MODEL=claude-opus-4-8          # AnthropicVertex SDK (bare id)
# FF_AGENT_MODEL=claude-opus-4-8[1m]       # Claude Agent SDK (suffixed id)
# FF_REQUEST_TIMEOUT_S=120
# FF_MAX_RETRIES=4

# ── MCP server ───────────────────────────────────────────────────────────────
# FF_MCP_TRANSPORT=stdio      # stdio | http
# FF_MCP_HTTP_HOST=127.0.0.1
# FF_MCP_HTTP_PORT=8848

# ── Orchestration reliability ────────────────────────────────────────────────
# FF_STEP_TIMEOUT_S=240
# FF_MAX_TURNS=60

# ── Audit & API access control ───────────────────────────────────────────────
# FF_AUDIT_ENABLED=true
# FF_AUDIT_LOG_PATH=out/audit.jsonl
# FF_API_REQUIRE_AUTH=false
# FF_API_TOKEN=

# ── Logging ──────────────────────────────────────────────────────────────────
# FF_LOG_LEVEL=INFO
# FF_LOG_JSON=false
